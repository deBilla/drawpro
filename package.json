{
  "name": "drawpro",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=!@drawpro/collab",
    "build": "turbo run build --filter=!@drawpro/collab",
    "dev:collab": "turbo run dev",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:seed": "cd apps/api && npx tsx prisma/seed.ts",
    "docker:up": "docker-compose -f infra/docker-compose.yml up --build"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  }
}
