generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  // E2EE fields (null until user sets up encryption)
  publicKey           String?  // base64 raw 32-byte X25519 public key
  encryptedPrivateKey String?  // base64 blob: iv(16)|AES-GCM(argon2id(passcode), pem)
  salt                String?  // hex — used for argon2id and PBKDF2 recovery codes
  recoveryCodesData   String?  // JSON: RecoveryCodeData[] — 6 PBKDF2-encrypted passcode backups
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ownedWorkspaces      Workspace[]
  workspaceMemberships WorkspaceMember[]
}

model Workspace {
  id            String   @id @default(cuid())
  name          String
  encryptedName String?  // base64 ECIES blob — client-encrypted name
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner   User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  sheets  Sheet[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Sheet {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  // Plaintext storage (used when user has no encryption keys)
  elements           Json?
  appState           Json?
  // Encrypted storage — single blob: eph_pub(32)|iv(16)|authTag(16)|ciphertext
  encryptedData      String?
  version            Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
