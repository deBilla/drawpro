generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  publicKey                   String?  // base64 SPKI DER of X25519 public key
  encryptedPrivateKey         String?  // JSON: {ciphertext, iv, salt} — passcode-wrapped X25519 private key
  recoveryEncryptedPrivateKey String?  // JSON: {ciphertext, iv} — recovery-key-wrapped X25519 private key
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ownedWorkspaces      Workspace[]
  workspaceMemberships WorkspaceMember[]
}

model Workspace {
  id            String   @id @default(cuid())
  name          String
  encryptedName String?  // JSON: {ciphertext,iv,authTag,ephemeralPublicKey} — client-encrypted name
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner   User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  sheets  Sheet[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Sheet {
  id                 String   @id @default(cuid())
  workspaceId        String
  name               String
  // Plaintext storage (used when user has no encryption keys)
  elements           Json?
  appState           Json?
  // Encrypted storage (used when user has encryption keys set up)
  ciphertext         String?  // base64 AES-256-GCM encrypted JSON
  iv                 String?  // base64 12-byte AES-GCM IV
  authTag            String?  // base64 16-byte AES-GCM auth tag
  ephemeralPublicKey String?  // base64 SPKI DER of server's ephemeral X25519 public key
  version            Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
