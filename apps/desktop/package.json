{
  "name": "@drawpro/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "DrawPro desktop app — Excalidraw with AI feedback via local Ollama",
  "author": "DrawPro",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run electron:dev",
    "electron:dev": "tsc -p tsconfig.json && ELECTRON_RUN_AS_NODE= electron .",
    "build": "tsc -p tsconfig.json && electron-builder",
    "build:mac": "tsc -p tsconfig.json && electron-builder --mac",
    "build:win": "tsc -p tsconfig.json && electron-builder --win",
    "build:linux": "tsc -p tsconfig.json && electron-builder --linux"
  },
  "dependencies": {
    "app-builder-bin": "^4.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0",
    "fast-xml-builder": "^1.1.4",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.drawpro.desktop",
    "productName": "DrawPro",
    "files": [
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "directories": {
      "output": "release"
    }
  }
}
