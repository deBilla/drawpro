{
  "manifest_version": 3,
  "name": "DrawPro Ollama Bridge",
  "version": "2.0.0",
  "description": "Enables DrawPro to connect to your local Ollama instance for AI feedback.",
  "permissions": [],
  "host_permissions": ["http://localhost:11434/*", "http://127.0.0.1:11434/*"],
  "externally_connectable": {
    "matches": ["https://drawpro.kithly.app/*", "http://localhost:*/*"]
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
