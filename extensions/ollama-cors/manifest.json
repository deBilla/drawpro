{
  "manifest_version": 3,
  "name": "DrawPro Ollama Bridge",
  "version": "1.0.1",
  "description": "Enables DrawPro to connect to your local Ollama instance for AI feedback.",
  "permissions": ["declarativeNetRequest", "declarativeNetRequestFeedback"],
  "host_permissions": ["http://localhost:11434/*", "http://127.0.0.1:11434/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ollama_cors",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
